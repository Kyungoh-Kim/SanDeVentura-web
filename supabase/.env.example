# Supabase Edge Functions local environment template.
#
# Copy to .env.local and run functions with:
#   npx supabase functions serve upload-session --no-verify-jwt --env-file supabase/.env.local
#
# Do not commit the copied file.

SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
SPRINT2_DEV_USER_ID=00000000-0000-4000-8000-000000000001
