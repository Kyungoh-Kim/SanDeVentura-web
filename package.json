{
  "name": "san-de-ventura-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:functions": "npx deno test --allow-env=SUPABASE_URL,SUPABASE_SERVICE_ROLE_KEY,SPRINT2_DEV_USER_ID supabase/tests/functions",
    "test:db": "npx supabase test db",
    "supabase:reset": "npx supabase db reset",
    "supabase:functions": "npx supabase functions serve upload-session --no-verify-jwt --env-file supabase/.env.local"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
